{
  "name": "monitoring-dashboard",
  "version": "1.0.0",
  "description": "智能监控大屏系统 - 基于Next.js的企业级网络监控平台",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "dev:all": "node scripts/dev-all.js",
    "build": "next build && node scripts/copy-standalone-static.js",
    "start": "node scripts/start-all.js",
    "start:server": "next start -H 0.0.0.0",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "add-unmanaged-enum": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/add-unmanaged-enum.ts",
    "collector": "node scripts/run-collector.js",
    "mock-collector": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/start-mock-collector.ts",
    "diagnose:dashboard": "tsx scripts/diagnose-dashboard-api.ts",
    "diagnose:database": "tsx scripts/diagnose-database-data.ts",
    "diagnose:all": "npm run diagnose:database && npm run diagnose:dashboard",
    "diagnose:production": "tsx scripts/production-full-diagnosis.ts",
    "diagnose:opmanager": "tsx scripts/verify-opmanager-real-data.ts",
    "check:business-details": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/check-getBusinessDetailsView.ts",
    "diagnose:api-calls": "tsx scripts/diagnose-api-calls.ts",
    "diagnose:collector": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/diagnose-production-collector.ts",
    "diagnose:collector:prod": "node scripts/diagnose-collector-prod.js",
    "diagnose:redis-opmanager": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/diagnose-redis-opmanager.ts",
    "diagnose:redis-opmanager:quick": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/quick-check-redis-opmanager.ts",
    "verify:production": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/verify-production-sync.ts",
    "verify:data-flow": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/verify-production-data-flow.ts",
    "diagnose:display": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/diagnose-dashboard-display.ts",
    "diagnose:api-calls:prod": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/diagnose-api-calls.ts",
    "test:env": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/test-env.ts",
    "check:isManaged": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/check-opmanager-isManaged.ts",
    "fix:isMonitored": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/fix-isMonitored.ts",
    "check:device": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/check-device-by-ip.ts",
    "check:sync": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/check-device-sync-status.ts",
    "check:interfaces": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/check-interface-count.ts",
    "check:all": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/check-sync-status.ts",
    "check:alarms": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/check-alarm-sync.ts",
    "check:tags": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/check-device-tags.ts",
    "check:metrics": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/check-device-metrics.ts",
    "check:redis": "ts-node --project tsconfig.node.json scripts/check-redis-standalone.ts",
    "clean:orphaned": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/clean-orphaned-data.ts",
    "check:interface-detail": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/check-interface-sync-detail.ts",
    "diagnose:bv-test2": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/diagnose-bv-test2.ts",
    "diagnose:topology-edges": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/diagnose-topology-edges.ts",
    "analyze:bvdetails-edges": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/analyze-bvdetails-edges.ts",
    "test:improved-topology-sync": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/test-improved-topology-sync.ts",
    "fix:topology-edges": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/fix-topology-edges.ts",
    "sync:bv-safe": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/sync-bv-with-lock.ts",
    "test:alarm-sync": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/test-alarm-sync.ts",
    "verify:opmanager-apis": "ts-node -r tsconfig-paths/register --project tsconfig.node.json scripts/verify-all-opmanager-apis.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "generate:ubuntu-migration": "node scripts/generate-ubuntu-migration.js"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.node.json prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@reactflow/core": "^11.11.4",
    "@socket.io/redis-adapter": "^8.2.1",
    "@types/lodash": "^4.17.21",
    "@types/react-grid-layout": "^1.3.6",
    "axios": "^1.6.2",
    "clsx": "^2.1.1",
    "d3-hierarchy": "^3.1.2",
    "d3-shape": "^3.2.0",
    "dagre": "^0.8.5",
    "date-fns": "^3.0.0",
    "framer-motion": "^10.16.16",
    "graphology-layout-forceatlas2": "^0.10.1",
    "ioredis": "^5.3.2",
    "lodash": "^4.17.21",
    "lucide-react": "^0.561.0",
    "next": "^14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^2.1.1",
    "reactflow": "^11.11.4",
    "recharts": "^2.10.3",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "tailwind-merge": "^3.4.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/dagre": "^0.7.53",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "autoprefixer": "^10.4.16",
    "dotenv": "^17.2.3",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "^9.1.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "node-mocks-http": "^1.17.2",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "prisma": "^5.7.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
