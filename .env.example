# ==================== 数据库配置 ====================
DATABASE_URL="postgresql://postgres:zww0625wh@localhost:5432/monitoring-dashboard?schema=public"

# ==================== Redis 配置 ====================
# Redis 连接 URL
REDIS_URL=redis://localhost:6379

# Redis 密码（可选，如果 Redis 没有设置密码则留空）
REDIS_PASSWORD=

# ==================== OpManager 配置 ====================
# OpManager 服务器地址
OPMANAGER_BASE_URL=https://opmanager.example.com

# OpManager API Key (从 OpManager 控制台获取)
OPMANAGER_API_KEY=your-api-key-here

# 请求超时时间（毫秒）
OPMANAGER_TIMEOUT=60000

# getInterfaces API 调用间隔（毫秒），避免触发 OpManager 限流
# 默认 30000 (30秒)，如果遇到 URL_ROLLING_THROTTLES_LIMIT_EXCEEDED 错误可增大此值
OPMANAGER_GETINTERFACES_DELAY_MS=30000

# ==================== WebSocket 配置 ====================
NEXT_PUBLIC_WS_URL=http://localhost:3000

# ==================== 应用配置 ====================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# ==================== 数据采集配置 ====================
# 设备指标采集间隔（秒）- 采集设备 CPU/内存/磁盘等性能指标
COLLECT_METRICS_INTERVAL=240

# 接口流量采集间隔（秒）- 采集接口流量数据
COLLECT_INTERFACE_INTERVAL=240

# 告警同步间隔（秒）- 从 OpManager 同步告警数据
COLLECT_ALARMS_INTERVAL=120

# 拓扑/业务视图同步间隔（秒）- 同步网络拓扑结构
SYNC_TOPOLOGY_INTERVAL=240

# 设备列表同步间隔（秒）- 手动触发，此值仅供参考
SYNC_DEVICES_INTERVAL=2400

# ==================== 数据保留策略 ====================
# 历史数据保留天数
DATA_RETENTION_DAYS=30

# ==================== 安全配置 ====================
# JWT密钥（生产环境请使用强随机字符串）
JWT_SECRET=your-random-secret-key-here-change-in-production

# API限流（请求/分钟）
API_RATE_LIMIT=100

# ==================== 日志配置 ====================
LOG_LEVEL=info
