# ==================== 生产环境配置示例 ====================
# 请复制此文件为 .env 并填入实际的生产环境配置

# ==================== 数据库配置 ====================
DATABASE_URL="postgresql://postgres:your-password@localhost:5432/monitoring-dashboard?schema=public"

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ==================== OpManager 生产环境配置 ====================
# OpManager 服务器地址 (生产环境)
# 格式: https://your-opmanager-host:port
OPMANAGER_BASE_URL=https://your-opmanager-host:8061

# OpManager API Key (生产环境)
# 从 OpManager 管理界面获取: 设置 > 集成 > API 密钥
OPMANAGER_API_KEY=your-api-key-here

# 请求超时时间（毫秒）- 生产环境建议设置较长时间
OPMANAGER_TIMEOUT=30000

# 如果遇到 SSL 证书问题,可以设置 (仅用于开发/测试,生产环境不推荐)
# NODE_TLS_REJECT_UNAUTHORIZED=0

# ==================== WebSocket 配置 ====================
NEXT_PUBLIC_WS_URL=http://your-production-server:3000

# ==================== 应用配置 ====================
NEXT_PUBLIC_APP_URL=http://your-production-server:3000
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# ==================== 数据采集配置 ====================
# 设备指标采集间隔（秒）
COLLECT_METRICS_INTERVAL=60

# 告警同步间隔（秒）
COLLECT_ALARMS_INTERVAL=30

# 设备列表同步间隔（秒）- 生产环境建议设置较长间隔
SYNC_DEVICES_INTERVAL=600

# ==================== 数据保留策略 ====================
# 历史数据保留天数
DATA_RETENTION_DAYS=30

# ==================== 安全配置 ====================
# JWT密钥（生产环境必须使用强随机字符串）
JWT_SECRET=your-strong-random-secret-key-change-this-in-production

# API限流（请求/分钟）
API_RATE_LIMIT=100

# ==================== 日志配置 ====================
LOG_LEVEL=info

# ==================== Business View 配置 ====================
# 默认的 Business View 名称
DEFAULT_BUSINESS_VIEW=出口业务
